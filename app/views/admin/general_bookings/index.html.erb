<div class="admin-page">
  <div class="admin-header">
    <h1>General Bookings</h1>

    <div class="admin-actions">
      <%= link_to "All",
        admin_general_bookings_path,
        class: "admin-link #{"active-bookings" if params[:status].blank?}" %>

      <%= link_to "Pending",
        admin_general_bookings_path(status: "pending"),
        class: "admin-link #{"active-bookings" if params[:status] == "pending"}" %>

      <%= link_to "Approved",
        admin_general_bookings_path(status: "approved"),
        class: "admin-link #{"active-bookings" if params[:status] == "approved"}" %>

      <%= link_to "Rejected",
        admin_general_bookings_path(status: "rejected"),
        class: "admin-link #{"active-bookings" if params[:status] == "rejected"}" %>
    </div>
  </div>
  <div class="admin-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Location</th>
          <th>Name</th>
          <th>Email</th>
          <th>Dates</th>
          <th>Activity</th>
          <th>Status</th>
          <th>See</th>
        </tr>
      </thead>
      <tbody>
        <% @bookings.each do |booking| %>
          <%= render "admin/general_bookings/booking_row", booking: booking %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
